generator client {
  provider      = "prisma-client-js"
  output        = "../../node_modules/.prisma/client"
  binaryTargets = ["native", "windows", "darwin"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("cashier")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryToChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryToChildren")

  @@unique([name, parentId])
}

model Product {
  id                     Int             @id @default(autoincrement())
  name                   String
  barcode                String?         @unique
  category               String?
  batchTrackingEnabled   Boolean         @default(false)
  lowStockThreshold      Int             @default(0)
  lowStockWarningEnabled Boolean         @default(false)
  isDeleted              Boolean         @default(false)
  deletedAt              DateTime?
  createdAt              DateTime        @default(now())
  batches                Batch[]
  promotions             PromotionItem[]
  movements              StockMovement[]

  @@index([category])
}

model Batch {
  id               Int             @id @default(autoincrement())
  productId        Int
  batchCode        String?
  quantity         Int             @default(0)
  mrp              Float
  costPrice        Float
  sellingPrice     Float
  wholesaleEnabled Boolean         @default(false)
  wholesalePrice   Float?
  wholesaleMinQty  Int?
  expiryDate       DateTime?
  createdAt        DateTime        @default(now())
  product          Product         @relation(fields: [productId], references: [id])
  saleItems        SaleItem[]
  movements        StockMovement[]

  @@index([productId])
}

model Customer {
  id              Int      @id @default(autoincrement())
  phone           String   @unique
  name            String?
  customerBarcode String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sales           Sale[]

  @@index([phone])
  @@index([customerBarcode])
}

model Sale {
  id            Int       @id @default(autoincrement())
  totalAmount   Float
  discount      Float     @default(0)
  extraDiscount Float     @default(0)
  paymentMethod String    @default("Cash")
  customerId    Int?
  createdAt     DateTime  @default(now())
  customer      Customer? @relation(fields: [customerId], references: [id])
  items         SaleItem[]

  @@index([createdAt])
  @@index([customerId])
}

model SaleItem {
  id               Int     @id @default(autoincrement())
  saleId           Int
  batchId          Int
  quantity         Int
  returnedQuantity Int     @default(0)
  sellingPrice     Float
  costPrice        Float
  mrp              Float
  isWholesale      Boolean @default(false)
  isFree           Boolean @default(false)
  batch            Batch   @relation(fields: [batchId], references: [id])
  sale             Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([batchId])
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  batchId   Int?
  type      String
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
  batch     Batch?   @relation(fields: [batchId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([batchId])
  @@index([createdAt])
}

model LooseSale {
  id        Int      @id @default(autoincrement())
  itemName  String?
  price     Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Promotion {
  id        Int             @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     PromotionItem[]

  @@index([startDate, endDate])
}

model PromotionItem {
  id                 Int       @id @default(autoincrement())
  promotionId        Int
  productId          Int
  promoPrice         Float
  discountPercentage Float?
  createdAt          DateTime  @default(now())
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  promotion          Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([productId])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Expense {
  id            Int              @id @default(autoincrement())
  amount        Float
  category      String           // 'Electricity', 'Rent', 'Wages', 'WiFi', 'Maintenance', 'Misc'
  description   String?
  date          DateTime         @default(now())
  paymentStatus String           @default("Paid") // "Paid", "Unpaid", "Due"
  paymentMethod String?          @default("Cash")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  payments      ExpensePayment[]

  @@index([date])
}

model ExpensePayment {
  id            Int      @id @default(autoincrement())
  expenseId     Int
  amount        Float
  paymentMethod String?
  date          DateTime @default(now())
  note          String?
  createdAt     DateTime @default(now())
  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([date])
}

model Purchase {
  id            Int             @id @default(autoincrement())
  vendor        String?
  totalAmount   Float
  date          DateTime        @default(now())
  note          String?
  paymentStatus String          @default("Paid") // "Paid", "Unpaid", "Due"
  paymentMethod String?         @default("Cash")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         PurchaseItem[]
  payments      PurchasePayment[]

  @@index([date])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  batchId    Int?
  productId  Int
  quantity   Int
  costPrice  Float
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
}

model PurchasePayment {
  id            Int      @id @default(autoincrement())
  purchaseId    Int
  amount        Float
  paymentMethod String?
  date          DateTime @default(now())
  note          String?
  createdAt     DateTime @default(now())
  purchase      Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([date])
}
